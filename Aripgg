local ESP_Data = {}

local function createESP(plr)
    if plr == LP then return end

    ESP_Data[plr] = {
        Text = Drawing.new("Text"),
        Box = Drawing.new("Square"),
        Tracer = Drawing.new("Line"),
        Health = Drawing.new("Line"),
        HealthText = Drawing.new("Text"),
        Highlight = Instance.new("Highlight")
    }

    local d = ESP_Data[plr]

    -- TEXT
    d.Text.Size = 15
    d.Text.Center = true
    d.Text.Outline = true
    d.Text.Color = Color3.fromRGB(0,255,255)

    -- BOX
    d.Box.Thickness = 1
    d.Box.Color = Color3.fromRGB(0,255,255)
    d.Box.Filled = false

    -- TRACER
    d.Tracer.Thickness = 1
    d.Tracer.Color = Color3.fromRGB(0,255,255)

    -- HEALTH BAR
    d.Health.Thickness = 2
    d.Health.Color = Color3.fromRGB(0,255,0)

    -- HIGHLIGHT
    d.Highlight.FillTransparency = 0.5
    d.Highlight.OutlineColor = Color3.fromRGB(0,255,255)
end

for _,p in pairs(Players:GetPlayers()) do
    createESP(p)
end

Players.PlayerAdded:Connect(createESP)

Players.PlayerRemoving:Connect(function(plr)
    if ESP_Data[plr] then
        for _,v in pairs(ESP_Data[plr]) do
            pcall(function() v:Remove() end)
            pcall(function() v:Destroy() end)
        end
        ESP_Data[plr] = nil
    end
end)

