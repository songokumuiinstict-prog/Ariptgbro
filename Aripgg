            -- tengah
            create(spawnPos + Vector3.new(0,y,0))

            -- samping
            for s = 1, side do
                create(spawnPos + Vector3.new(s*lebar,y,0))
                create(spawnPos + Vector3.new(-s*lebar,y,0))
            end
        end

    end)
