local function spawnObject(type)
local char = LP.Character
local hrp = char and char:FindFirstChild("HumanoidRootPart")
if not hrp then return end

local p = Instance.new(type == "Segitiga" and "WedgePart" or "Part")  
p.Name = "PunkX_Created"  
p.Size = Vector3.new(States.PartWide, States.PartTall, States.PartLong)  
p.BrickColor = BrickColor.new(States.PartColor)  
p.Anchored = true  
p.CanCollide = true  
  
-- Logika Posisi  
if type == "Jalan" then  
-- Menggunakan States.PartDeg yang diambil dari Input Box tadi  
p.CFrame = hrp.CFrame * CFrame.new(0, 2, -(States.PartLong/2 + 4)) * CFrame.Angles(math.rad(States.PartDeg or 15), 0, 0)  
else  
    -- Muncul 8 stud di depan muka  
    p.CFrame = hrp.CFrame * CFrame.new(0, 0, -8)  
end  
  
p.Parent = workspace

end

