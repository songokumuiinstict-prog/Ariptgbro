local function isDangerous(p)
if not p:IsA("BasePart") then return false end
local n = p.Name:lower()

return (  
    string.find(n,"kill") or  
    string.find(n,"damage") or  
    string.find(n,"lava") or  
    string.find(n,"laser") or  
    (p.Material == Enum.Material.Neon and p.CanTouch)  
)

end

