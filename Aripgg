-- ================= SMART FIND PLAYER =================
local function findPlayerSmart(input)
if not input or input == "" then return nil end
input = string.lower(input)

for _,plr in pairs(Players:GetPlayers()) do  
    local name = string.lower(plr.Name)  
    local display = string.lower(plr.DisplayName)  

    if string.find(name, input) or string.find(display, input) then  
        return plr  
    end  
end

end

-- ================= CREATE DRONE =================
local function createDrone(targetPlayer, randomMode)
if not targetPlayer then return end
if #States.ActiveDrones >= States.MaxDrones then return end

local drone = Instance.new("Model")  
drone.Name = "Drone_"..(#States.ActiveDrones+1)  
drone.Parent = workspace  

-- BODY  
local body = Instance.new("Part")  
body.Name = "MainBody"  
body.Size = Vector3.new(3,0.6,3)  
body.Anchored = true  
body.Material = Enum.Material.Metal  
body.BrickColor = BrickColor.new("Dark stone grey")  
body.Parent = drone  

-- LABEL NOMOR  
local bb = Instance.new("BillboardGui", body)  
bb.Size = UDim2.new(0,100,0,50)  
bb.AlwaysOnTop = true  

local txt = Instance.new("TextLabel", bb)  
txt.Size = UDim2.new(1,0,1,0)  
txt.BackgroundTransparency = 1  
txt.Text = "Drone #"..(#States.ActiveDrones+1)  
txt.TextColor3 = Color3.new(1,1,1)  
txt.TextStrokeTransparency = 0  

-- BALING-BALING REAL  
local props = {}  
local offsets = {  
    Vector3.new(2,0.5,2),  
    Vector3.new(-2,0.5,2),  
    Vector3.new(2,0.5,-2),  
    Vector3.new(-2,0.5,-2)  
}  

for _,off in pairs(offsets) do  
    local prop = Instance.new("Part")  
    prop.Size = Vector3.new(1.5,0.1,0.3)  
    prop.Anchored = true  
    prop.CanCollide = false  
    prop.Material = Enum.Material.Neon  
    prop.Transparency = 0.2  
    prop.BrickColor = BrickColor.new("Black")  
    prop.Parent = drone  

    table.insert(props, {part = prop, offset = off})  
end  

local data = {  
    Model = drone,  
    Body = body,  
    Props = props,  
    Target = targetPlayer,  
    Random = randomMode,  
    LastSwitch = tick()  
}  

table.insert(States.ActiveDrones, data)

end

-- ================= LOOP GLOBAL =================
RunService.RenderStepped:Connect(function()
local spin = tick() * 60

for _,d in pairs(States.ActiveDrones) do  
    if d.Model and d.Body then  

        -- RANDOM TARGET  
        if d.Random and tick() - d.LastSwitch > 60 then  
            local plrs = Players:GetPlayers()  
            d.Target = plrs[math.random(1,#plrs)]  
            d.LastSwitch = tick()  
        end  

        -- FOLLOW  
        if d.Target and d.Target.Character and d.Target.Character:FindFirstChild("HumanoidRootPart") then  
            local pos = d.Target.Character.HumanoidRootPart.Position  
            d.Body.CFrame = CFrame.new(pos + Vector3.new(0,12,0))  
        end  

        -- PUTAR BALING-BALING  
        for _,p in pairs(d.Props) do  
            if p.part then  
                p.part.CFrame =  
                    d.Body.CFrame  
                    * CFrame.new(p.offset)  
                    * CFrame.Angles(0, spin, 0)  
            end  
        end  
    end  
end

end)

