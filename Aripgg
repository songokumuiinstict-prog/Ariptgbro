-- FUNCTION ROTATE
local function addRotateTool(name, axis)
    local btn = Instance.new("TextButton")
    btn.Text = "[GET] Rotate "..name
    btn.Size = UDim2.new(0.95,0,0,35)
    btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Parent = BMenu

    btn.MouseButton1Click:Connect(function()
        giveTool("Rotate"..name, function()
            local target = Mouse.Target
            if not (target and target:IsA("BasePart")) then return end

            local deg = math.rad(States.PartDeg or 15)

            if axis == "X" then
                target.CFrame *= CFrame.Angles(deg,0,0)
            elseif axis == "Y" then
                target.CFrame *= CFrame.Angles(0,deg,0)
            elseif axis == "Z" then
                target.CFrame *= CFrame.Angles(0,0,deg)
            end
        end)
    end)
end

