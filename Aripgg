-- ===== INTEGRATED MOVE TOOL V3 =====
local bMove = Instance.new("TextButton")
bMove.Text = "[GET] Move Tool (Stable)"; bMove.Size = UDim2.new(0.95, 0, 0, 35); bMove.Parent = BMenu
bMove.MouseButton1Click:Connect(function()
giveTool("Move", function()
local target = Mouse.Target
if not (target and target:IsA("BasePart")) then return end

local oldAnchored = target.Anchored  
    target.Anchored = true  

    local offset = target.CFrame:ToObjectSpace(Mouse.Hit)      
    local holding = true      

    local conn      
    conn = RunService.RenderStepped:Connect(function()      
        if not holding or not target.Parent then      
            conn:Disconnect()      
            target.Anchored = oldAnchored      
            return      
        end      
        target.CFrame = Mouse.Hit * offset:Inverse()      
    end)      

    Mouse.Button1Up:Wait()      
    holding = false  
end)

end)

